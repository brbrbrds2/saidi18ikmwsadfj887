-- Helper Functions
function USWARE:AddSignal(RBXSignal)
    table.insert(USWARE.GlobalSignals, RBXSignal)
    return RBXSignal
end

function USWARE:CreateSignal(DefaultValue)
    local cache = Instance.new('BindableEvent')
    local bind = {
        Value = DefaultValue,
        __event = cache
    }
    
    function bind:GetValue()
        return bind.Value
    end
    
    function bind:SetValue(f)
        bind.Value = f
        cache:Fire(f)
        return f
    end
    
    function bind:Connect(f)
        local signal = cache.Event:Connect(f)
        USWARE:AddSignal(signal)
        return signal
    end
    
    return bind
end

function USWARE:PlayAnimate(Self, Info, Property)
    local Tween = TweenService:Create(Self, Info or TweenInfo.new(0.25), Property)
    Tween:Play()
    return Tween
end

function USWARE:Drag(InputFrame, MoveFrame, Speed)
    local dragToggle = false
    local dragStart = nil
    local startPos = nil
    local Tween = TweenInfo.new(Speed)
    
    local updateInput = function(input)
        local delta = input.Position - dragStart
        local position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        USWARE:PlayAnimate(MoveFrame, Tween, {Position = position})
    end
    
    USWARE:AddSignal(InputFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then 
            dragToggle = true
            dragStart = input.Position
            startPos = MoveFrame.Position
            
            local input_end
            input_end = input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragToggle = false
                    input_end:Disconnect()
                end
            end)
        end
    end))
    
    USWARE:AddSignal(UserInputService.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            if dragToggle then
                updateInput(input)
            end
        end
    end))
end

function USWARE:CreateShadow(parent)
    local Shadow = {}
    
    local UIShadow1 = Instance.new("UIStroke")
    local UIShadow2 = Instance.new("UIStroke")
    local UIShadow3 = Instance.new("UIStroke")
    local UIShadow4 = Instance.new("UIStroke")
    
    UIShadow1.Thickness = 6
    UIShadow1.Transparency = 1
    UIShadow1.Parent = parent
    
    UIShadow2.Thickness = 5
    UIShadow2.Transparency = 1
    UIShadow2.Parent = parent
    
    UIShadow3.Thickness = 4
    UIShadow3.Transparency = 1
    UIShadow3.Parent = parent
    
    UIShadow4.Thickness = 3
    UIShadow4.Transparency = 1
    UIShadow4.Parent = parent
    
    Shadow.Render = function(self, value)
        if value then
            USWARE:PlayAnimate(UIShadow1, SlowyTween, {Transparency = 0.900})
            USWARE:PlayAnimate(UIShadow2, SlowyTween, {Transparency = 0.900})
            USWARE:PlayAnimate(UIShadow3, SlowyTween, {Transparency = 0.900})
            USWARE:PlayAnimate(UIShadow4, SlowyTween, {Transparency = 0.900})
        else
            USWARE:PlayAnimate(UIShadow1, SlowyTween, {Transparency = 1})
            USWARE:PlayAnimate(UIShadow2, SlowyTween, {Transparency = 1})
            USWARE:PlayAnimate(UIShadow3, SlowyTween, {Transparency = 1})
            USWARE:PlayAnimate(UIShadow4, SlowyTween, {Transparency = 1})
        end
    end
    
    return Shadow
end

